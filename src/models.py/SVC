# src/models/svm_model.py
from sklearn.svm import SVC
from sklearn.model_selection import cross_val_score
from sklearn.metrics import classification_report

def build_svm(C=0.5, kernel='linear', gamma='scale', random_state=1):
    return SVC(C=C, kernel=kernel, gamma=gamma, probability=True, random_state=random_state)

def train_svm(model, X_train, y_train):
    model.fit(X_train, y_train)
    return model

def evaluate_svm(model, X_val, y_val, target_names):
    preds = model.predict(X_val)
    print('SVM Classification Report:\n', classification_report(y_val, preds, target_names=target_names))
    scores = cross_val_score(model, X_val, y_val, cv=5, scoring='accuracy')
    print('Cross-validation scores:', scores)
    print('Average CV score:', scores.mean())
